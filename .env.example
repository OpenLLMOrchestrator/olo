# Olo Backend — environment variables (copy to .env to override)
# Spring Boot maps these to application.properties (e.g. SERVER_PORT → server.port).
# Used by: docker compose, bootRun, or any process that loads .env.

# Server
SERVER_PORT=7080

# Swagger UI (set false in production to disable /swagger-ui.html and /api-docs)
OLO_SWAGGER_UI_ENABLED=true

# Cache / Redis (sessions, kernel config queues)
OLO_CACHE_HOST=localhost
OLO_CACHE_PORT=6379
OLO_CACHE_DATABASE=0

# Temporal
OLO_TEMPORAL_TARGET=localhost:7233
OLO_TEMPORAL_NAMESPACE=default
OLO_TEMPORAL_TASK_QUEUE=olo-chat
OLO_TEMPORAL_WORKFLOW_TYPE=OloKernelWorkflow
OLO_WORKFLOW_TYPE=

# Callback URL the worker uses to POST run events (must be reachable by the worker)
OLO_CHAT_CALLBACK_BASE_URL=http://localhost:7080

# WebSocket (dev/demo: false; production: true)
OLO_WS_JWT_REQUIRED=false

# Default tenant (WebSocket when JWT bypassed + UI dropdown). Optional comma-separated list for UI.
OLO_DEFAULT_TENANT_ID=2a2a91fb-f5b4-4cf0-b917-524d242b2e3d
OLO_TENANT_IDS=

# Logging (optional)
# LOGGING_LEVEL_COM_OLO_APP_FILTER_REQUESTLOGGINGFILTER=INFO
# LOGGING_LEVEL_COM_OLO_APP_SERVICE_KERNELCONFIGQUEUESERVICE=DEBUG
